# 🔗 Backend API URL
# Aponta para o Application Load Balancer estável na AWS
NEXT_PUBLIC_API_URL=http://safewallet-alb-1695226228.us-east-1.elb.amazonaws.com/api

# 🌍 Ambiente
NEXT_PUBLIC_ENV=production

# 📱 Aplicação
