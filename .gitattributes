/mvnw text eol=lf
*.cmd text eol=crlf

# --- Otimização para o Java assumir o Card Principal ---

# Se você estiver usando AWS CDK para a Infraestrutura, ignore o output gerado:
cdk.out/* linguist-vendored
.cdk.staging/* linguist-vendored

# Ignorar arquivos de configuração e testes do ecossistema JS/TS (eles pesam muito)
*.config.ts linguist-vendored
*.config.js linguist-vendored
*.test.ts linguist-vendored
*.spec.ts linguist-vendored
package-lock.json linguist-vendored
yarn.lock linguist-vendored

# Se houver alguma pasta específica de componentes visuais pesados (ex: shadcn/ui ou build):
build/* linguist-vendored
dist/* linguist-vendored