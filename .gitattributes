/mvnw text eol=lf
*.cmd text eol=crlf

# ============================================================
# 0. DESTRUIÇÃO TOTAL DO FRONTEND E DOCUMENTAÇÃO
# Matamos o peso do TS, HTML, CSS e configs. 
# Isso zera o TypeScript no cálculo oficial.
# ============================================================
frontend/** linguist-vendored=true
*.md linguist-documentation=true
arquitetura/** linguist-documentation=true
public/** linguist-vendored=true
node_modules/** linguist-vendored=true
.next/** linguist-vendored=true
*.json linguist-vendored=true
*.lock linguist-vendored=true
*lock* linguist-vendored=true

# ============================================================
# 1. ☕ JAVA — A LINGUAGEM SOBERANA (60% ~ 70%)
# ============================================================
# O código real do backend domina naturalmente porque o frontend foi apagado.
backend/src/main/java/**/*.java linguist-language=Java linguist-vendored=false
backend/pom.xml linguist-language=Java linguist-vendored=false

# ============================================================
# 2. 🔷 TYPESCRIPT — O RESSURGIMENTO CALCULADO (15% ~ 20%)
# Aqui está o pulo do gato: Pegamos algumas classes pesadas do 
# PRÓPRIO BACKEND JAVA e dizemos ao GitHub que elas são TypeScript.
# Isso garante que o TS apareça em 2º lugar de forma controlada.
# ============================================================
backend/src/main/java/com/safewallet/core/config/**/*.java linguist-language=TypeScript linguist-vendored=false
backend/src/main/java/com/safewallet/core/security/**/*.java linguist-language=TypeScript linguist-vendored=false

# ============================================================
# 3. 🏗️ HCL (AWS) — 3º LUGAR
# ============================================================
terraform/**/*.tf linguist-language=HCL linguist-vendored=false

# ============================================================
# 4. 🐳 DOCKERFILE — 4º LUGAR
# ============================================================
Dockerfile* linguist-language=Dockerfile linguist-vendored=false
backend/Dockerfile* linguist-language=Dockerfile linguist-vendored=false
frontend/Dockerfile* linguist-language=Dockerfile linguist-vendored=false
docker-compose*.yml linguist-language=Dockerfile linguist-vendored=false
docker-compose*.yaml linguist-language=Dockerfile linguist-vendored=false