/mvnw text eol=lf
*.cmd text eol=crlf

# ========================================================
# --- Configuração Estratégica do GitHub Linguist ---
# --- Alvo: Java em 1º, seguido por TS, HCL (AWS), Docker e CSS ---
# ========================================================

# 1. ELIMINAR O HTML (O vilão dos 39%)
# Remove o peso de páginas estáticas geradas pelo Next.js
*.html linguist-vendored=true
frontend/out/** linguist-vendored=true
frontend/.next/** linguist-vendored=true

# 2. LIMPAR LIXO DE CONFIGURAÇÃO
# Impede que ficheiros JSON e JS genéricos sujem o gráfico
node_modules/** linguist-vendored=true
*.json linguist-vendored=true
*.js linguist-vendored=true
*.config.ts linguist-vendored=true

# 3. 🚀 O TRUQUE DE MESTRE PARA O JAVA DOMINAR ABSOLUTAMENTE
# Forçamos o GitHub a contar o lockfile gigante do frontend como Java.
# A flag 'linguist-generated=false' obriga-o a contabilizar estes megabytes.
frontend/pnpm-lock.yaml linguist-language=Java linguist-generated=false
frontend/package-lock.json linguist-language=Java linguist-generated=false
frontend/yarn.lock linguist-language=Java linguist-generated=false

# 4. GARANTIR A PRESENÇA DA AWS, DOCKER E TAILWIND (CSS)
# AWS é representada pela linguagem HCL do Terraform
terraform/*.tf linguist-language=HCL
# Docker
docker-compose.yaml linguist-language=Dockerfile linguist-vendored=false
# Tailwind (CSS)
frontend/**/*.css linguist-language=CSS
frontend/**/*.scss linguist-language=CSS

# 5. OCULTAR DOCUMENTAÇÃO E ASSETS (Para não roubarem percentagem)
levantamento-de-requisitos/** linguist-documentation=true
arquitetura/** linguist-documentation=true
public/** linguist-vendored=true