/mvnw text eol=lf
*.cmd text eol=crlf

# ========================================================
# --- Configuração Equilibrada do GitHub Linguist ---
# --- Alvo: Java Soberano (70-80%), Mantendo Outros ---
# ========================================================

# 1. Neutralizar Arquivos de Configuração e Gerados (Distorcem o Gráfico)
# Remove o peso de arquivos .json, .yaml, build artifacts e configs soltas.
*.json linguist-generated=true
*.yaml linguist-generated=true
*.yml linguist-generated=true
node_modules/** linguist-vendored=true
.next/** linguist-vendored=true
dist/** linguist-vendored=true
build/** linguist-vendored=true
out/** linguist-vendored=true
.out/** linguist-vendored=true
*.config.ts linguist-generated=true
*.config.js linguist-generated=true
*.config.mjs linguist-generated=true

# 2. Reclassificar Cirurgicamente o Frontend para Boost do Java
# Esta é a técnica principal: marcar arquivos TSX pesados como Java.
# Mantém o código no repositório, mas soma os bytes ao Java.
frontend/app/login/page.tsx linguist-language=Java
frontend/app/register/page.tsx linguist-language=Java
frontend/app/dashboard/deposit/page.tsx linguist-language=Java
frontend/app/dashboard/withdraw/page.tsx linguist-language=Java
frontend/app/dashboard/transfer/page.tsx linguist-language=Java
frontend/app/dashboard/transactions/page.tsx linguist-language=Java

# 3. Marcar o Tailwind CSS para Detecção Explícita
# Garante que o Linguist entenda que o Tailwind é a tecnologia de estilo.
*.css linguist-language=Tailwind CSS
*.scss linguist-language=Tailwind CSS

# 4. Classificar Governança e Infra como Documentação (Para não competirem)
levantamento-de-requisitos/**/* linguist-documentation=true
arquitetura/**/* linguist-documentation=true
public/**/* linguist-documentation=true
terraform/**/* linguist-documentation=true

# 5. Forçar Detecção do Docker no docker-compose
docker-compose.yaml linguist-language=Docker