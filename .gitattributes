# ============================================================
# .gitattributes — Controle de EOL + GitHub Linguist
# Ordem alvo: 1º Java · 2º TypeScript · 3º HCL · 4º Dockerfile
# ============================================================

# --- EOL ---
/mvnw text eol=lf
*.cmd text eol=crlf

# ============================================================
# 1. ☕ JAVA — 1º LUGAR
# src/**/*.java já conta nativamente; mvnw reforça a contagem.
# ATENÇÃO: NÃO vendorize *.json de forma global aqui —
# o openapi-safewallet.json precisa sobreviver para somar bytes.
# ============================================================
src/**/*.java          linguist-language=Java linguist-vendored=false
mvnw                   linguist-language=Java linguist-vendored=false
openapi-safewallet.json linguist-language=Java linguist-generated=false

# pom.xml é XML puro — o Linguist não aceita reclassificá-lo como Java.
# Melhor escondê-lo para não diluir a contagem.
pom.xml                linguist-documentation=true

# ============================================================
# 2. 🔷 TYPESCRIPT — 2º LUGAR
# Mantemos os .ts/.tsx do src; vendorizamos tudo que é build/lock.
# ============================================================
frontend/src/**/*.ts   linguist-language=TypeScript linguist-vendored=false
frontend/src/**/*.tsx  linguist-language=TypeScript linguist-vendored=false

frontend/.next/**              linguist-vendored=true
frontend/out/**                linguist-vendored=true
frontend/package-lock.json     linguist-vendored=true
frontend/pnpm-lock.yaml        linguist-vendored=true
frontend/yarn.lock             linguist-vendored=true
*.config.ts                    linguist-vendored=true
node_modules/**                linguist-vendored=true

# ============================================================
# 3. 🏗️ HCL / TERRAFORM — 3º LUGAR
# O .terraform.lock.hcl costuma ser pesado — não vendorize.
# ============================================================
terraform/**/*.tf              linguist-language=HCL linguist-vendored=false
terraform/.terraform.lock.hcl  linguist-language=HCL linguist-generated=false

# ============================================================
# 4. 🐳 DOCKERFILE — 4º LUGAR
# Dockerfile* e Compose ficam abaixo do HCL em volume.
# ============================================================
Dockerfile*                    linguist-language=Dockerfile linguist-vendored=false
docker-compose*.yaml           linguist-language=Dockerfile linguist-vendored=false
docker-compose*.yml            linguist-language=Dockerfile linguist-vendored=false
.dockerignore                  linguist-language=Dockerfile

# ============================================================
# 5. 🔇 ELIMINAÇÃO DE RUÍDO
# HTML, JS, CSS e JSON genéricos fora do openapi.
# IMPORTANTE: *.json aqui é aplicado DEPOIS da regra do openapi
# acima — o Linguist usa a última regra que bate no arquivo,
# então inverta a ordem se seu Linguist for sensível a isso.
# ============================================================
*.html                         linguist-vendored=true
*.js                           linguist-vendored=true
frontend/**/*.css              linguist-vendored=true
frontend/**/*.scss             linguist-vendored=true

# JSON genérico (lock files, configs) — mas NÃO o openapi acima.
# Se o seu openapi estiver na raiz, essa glob não o afeta.
frontend/**/*.json             linguist-vendored=true
**/package.json                linguist-vendored=true

# ============================================================
# 6. 📚 DOCUMENTAÇÃO / DIAGRAMAS
# ============================================================
levantamento-de-requisitos/**  linguist-documentation=true
arquitetura/**                 linguist-documentation=true
public/**                      linguist-vendored=true
README.md                      linguist-documentation=true