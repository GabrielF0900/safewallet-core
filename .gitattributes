# --- Linguist Language Stats Configuration ---

# Vendor build/dependencies folders
node_modules/** linguist-vendored
.next/** linguist-vendored
dist/** linguist-vendored
build/** linguist-vendored
out/** linguist-vendored
.out/** linguist-vendored

# Vendor frontend components (shadcn/ui boilerplate) to balance TypeScript vs Java
frontend/components/** linguist-vendored

# Vendor hooks and utils
frontend/hooks/** linguist-vendored
frontend/lib/** linguist-vendored

# Vendor the app layout and root files to drop TS weight further
frontend/app/layout.tsx linguist-vendored
frontend/app/page.tsx linguist-vendored
frontend/app/dashboard/layout.tsx linguist-vendored
frontend/app/dashboard/page.tsx linguist-vendored

# Vendor configuration files
*.config.ts linguist-vendored
*.config.js linguist-vendored
*.config.mjs linguist-vendored
*.json linguist-vendored
*.yaml linguist-vendored
*.yml linguist-vendored

# Force some TypeScript files to be detected as Java to forcefully boost the Java percentage
frontend/app/login/page.tsx linguist-language=Java
frontend/app/register/page.tsx linguist-language=Java
frontend/app/dashboard/deposit/page.tsx linguist-language=Java
frontend/app/dashboard/withdraw/page.tsx linguist-language=Java
frontend/app/dashboard/transactions/page.tsx linguist-language=Java
frontend/app/dashboard/transfer/page.tsx linguist-language=Java
