/mvnw text eol=lf
*.cmd text eol=crlf

# ========================================================
# --- Configuração Avançada do GitHub Linguist (Foco em Java) ---
# ========================================================

# 1. Neutralizar completamente o ecossistema do Frontend (Next.js / React / Tailwind)
# Isso remove todo e qualquer peso de TypeScript, TSX, JS, HTML e CSS do gráfico global
frontend/**/* linguist-vendored=true

# 2. Neutralizar pastas de dependências, builds, históricos e caches locais
node_modules/** linguist-vendored=true
.next/** linguist-vendored=true
dist/** linguist-vendored=true
build/** linguist-vendored=true
out/** linguist-vendored=true
.out/** linguist-vendored=true
.history/** linguist-vendored=true
.vscode/** linguist-vendored=true

# 3. Blindagem de segurança por extensões de arquivos de UI/Scripts soltos
*.html linguist-generated=true
*.css linguist-generated=true
*.scss linguist-generated=true
*.js linguist-generated=true
*.jsx linguist-generated=true
*.ts linguist-generated=true
*.tsx linguist-generated=true

# 4. Neutralizar arquivos de configuração e IaC (Terraform) para não competirem com o Java
*.config.ts linguist-vendored=true
*.config.js linguist-vendored=true
*.config.mjs linguist-vendored=true
*.json linguist-vendored=true
*.yaml linguist-vendored=true
*.yml linguist-vendored=true
terraform/**/* linguist-documentation=true
docker-compose.yaml linguist-vendor=true

# 5. Classificar formalmente as pastas de governança como documentação técnica
levantamento-de-requisitos/**/* linguist-documentation=true
arquitetura/**/* linguist-documentation=true
public/**/* linguist-documentation=true