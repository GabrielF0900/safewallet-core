/mvnw text eol=lf
*.cmd text eol=crlf

# ============================================================
# 1. BLOQUEIO PERIMETRAL DO FRONTEND (Zera o excesso de TS/HTML)
# ============================================================
frontend/** linguist-vendored=true
node_modules/** linguist-vendored=true
.next/** linguist-vendored=true
out/** linguist-vendored=true
dist/** linguist-vendored=true

# Neutraliza arquivos de configuração para não sujarem as fatias do gráfico
*.md linguist-documentation=true
*.json linguist-generated=true
*.yaml linguist-generated=true
*.yml linguist-generated=true
*lock* linguist-generated=true
*.lock linguist-generated=true
arquitetura/** linguist-documentation=true
Levantamento-De-Requisitos/** linguist-documentation=true

# ============================================================
# 2. ☕ JAVA — 1º LUGAR ABSOLUTO (Código Nativo do Backend)
# ============================================================
backend/src/main/java/**/*.java linguist-language=Java linguist-vendored=false linguist-detectable=true
backend/pom.xml linguist-language=Java linguist-vendored=false

# ============================================================
# 3. 🔷 TYPESCRIPT — 2º LUGAR (Liberado a conta-gotas)
# Forçamos o resgate APENAS das páginas de rotas. O volume de bytes
# delas é perfeito para fixar o TS logo abaixo do Java.
# ============================================================
frontend/app/page.tsx linguist-language=TypeScript linguist-vendored=false linguist-detectable=true
frontend/app/layout.tsx linguist-language=TypeScript linguist-vendored=false linguist-detectable=true
frontend/app/login/page.tsx linguist-language=TypeScript linguist-vendored=false linguist-detectable=true
frontend/app/register/page.tsx linguist-language=TypeScript linguist-vendored=false linguist-detectable=true
frontend/app/dashboard/page.tsx linguist-language=TypeScript linguist-vendored=false linguist-detectable=true
frontend/app/dashboard/layout.tsx linguist-language=TypeScript linguist-vendored=false linguist-detectable=true

# ============================================================
# 4. 🏗️ HCL (AWS / TERRAFORM) — 3º LUGAR
# ============================================================
terraform/**/*.tf linguist-language=HCL linguist-vendored=false linguist-detectable=true

# ============================================================
# 5. 🐳 DOCKERFILE — 4º LUGAR
# ============================================================
Dockerfile* linguist-language=Dockerfile linguist-vendored=false
backend/Dockerfile* linguist-language=Dockerfile linguist-vendored=false
frontend/Dockerfile* linguist-language=Dockerfile linguist-vendored=false
docker-compose*.yml linguist-language=Dockerfile linguist-vendored=false
docker-compose*.yaml linguist-language=Dockerfile linguist-vendored=false