/mvnw text eol=lf
*.cmd text eol=crlf

# ============================================================
# 1. EXCLUSÕES GLOBAIS
# ============================================================
*.html  linguist-vendored=true
*.json  linguist-generated=true
*.lock  linguist-generated=true
*lock*  linguist-generated=true
*.md    linguist-documentation=true
*.yaml  linguist-generated=true
*.yml   linguist-generated=true
*.mjs   linguist-detectable=false
*.cjs   linguist-detectable=false
*.css   linguist-detectable=false
*.scss  linguist-detectable=false
*.js    linguist-detectable=false
*.jsx   linguist-detectable=false

# ============================================================
# 2. TYPESCRIPT — bloqueio global total
# ============================================================
*.ts    linguist-detectable=false
*.tsx   linguist-detectable=false

# Pastas de dependências e build
frontend/.next/**    linguist-vendored=true
frontend/out/**      linguist-vendored=true
node_modules/**      linguist-vendored=true

# Documentações
arquitetura/**                  linguist-documentation=true
Levantamento-De-Requisitos/**   linguist-documentation=true
levantamento-de-requisitos/**   linguist-documentation=true

# ============================================================
# 3. ☕ JAVA — 1º LUGAR
# ============================================================
backend/src/main/java/**/*.java   linguist-language=Java linguist-detectable=true linguist-vendored=false
backend/src/test/java/**/*.java   linguist-language=Java linguist-detectable=true linguist-vendored=false

# ============================================================
# 4. 🔷 TYPESCRIPT — 2º LUGAR
# Apenas os arquivos de entrada da aplicação (app root)
# ============================================================
frontend/app/page.tsx     linguist-language=TypeScript linguist-detectable=true linguist-vendored=false
frontend/app/layout.tsx   linguist-language=TypeScript linguist-detectable=true linguist-vendored=false
frontend/app/login/page.tsx      linguist-language=TypeScript linguist-detectable=true linguist-vendored=false
frontend/app/register/page.tsx   linguist-language=TypeScript linguist-detectable=true linguist-vendored=false

# ============================================================
# 5. 🏗️ HCL (Terraform / AWS) — 3º LUGAR
# ============================================================
terraform/**/*.tf       linguist-language=HCL linguist-detectable=true linguist-vendored=false
terraform/**/*.tfvars   linguist-language=HCL linguist-detectable=true linguist-vendored=false

# ============================================================
# 6. 🐳 DOCKERFILE — 4º LUGAR
# ============================================================
Dockerfile              linguist-language=Dockerfile linguist-detectable=true linguist-vendored=false linguist-generated=false
Dockerfile*             linguist-language=Dockerfile linguist-detectable=true linguist-vendored=false linguist-generated=false
backend/Dockerfile*     linguist-language=Dockerfile linguist-detectable=true linguist-vendored=false linguist-generated=false
frontend/Dockerfile*    linguist-language=Dockerfile linguist-detectable=true linguist-vendored=false linguist-generated=false