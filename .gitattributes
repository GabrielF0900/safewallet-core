# ============================================================
# .gitattributes — EOL + GitHub Linguist
# Alvo: 1º Java (Dominante) · 2º TypeScript · 3º HCL · 4º Docker
# ============================================================

# --- EOL ---
backend/mvnw text eol=lf
*.cmd        text eol=crlf

# ============================================================
# 0. 🔇 ELIMINAÇÃO DE RUÍDO & DOCUMENTAÇÃO GERAL
# ============================================================
*.md                            linguist-documentation=true
Levantamento-De-Requisitos/** linguist-documentation=true
arquitetura/** linguist-documentation=true
public/** linguist-vendored=true
README.md                       linguist-documentation=true
*.html                          linguist-vendored=true
*.js                            linguist-vendored=true
*.mjs                           linguist-vendored=true
*.css                           linguist-vendored=true
*.scss                          linguist-vendored=true
pom.xml                         linguist-vendored=true

# ============================================================
# 1. ☕ JAVA — 1º LUGAR (O Truque do Peso)
# ============================================================
# Código real do backend
backend/src/**/*.java           linguist-language=Java linguist-vendored=false linguist-detectable=true
backend/mvnw                    linguist-language=Java linguist-vendored=false linguist-detectable=true
backend/src/main/resources/** linguist-language=Java linguist-vendored=false linguist-detectable=true
openapi-safewallet.json         linguist-language=Java linguist-vendored=false linguist-generated=false linguist-detectable=true

# 🚀 BOMBA DE BYTES: Transforma os arquivos de lock pesados em Java
*lock* linguist-language=Java linguist-vendored=false linguist-generated=false linguist-detectable=true
*.lock                          linguist-language=Java linguist-vendored=false linguist-generated=false linguist-detectable=true
frontend/pnpm-lock.yaml         linguist-language=Java linguist-vendored=false linguist-generated=false linguist-detectable=true
frontend/package-lock.json      linguist-language=Java linguist-vendored=false linguist-generated=false linguist-detectable=true
frontend/yarn.lock              linguist-language=Java linguist-vendored=false linguist-generated=false linguist-detectable=true

# ============================================================
# 2. 🔷 TYPESCRIPT — 2º LUGAR (Apenas o essencial)
# ============================================================
# Ocultamos todo o frontend para matar o volume
frontend/** linguist-vendored=true
# Resgatamos apenas a pasta 'app' e 'components' para o TS aparecer
frontend/app/**/*.ts            linguist-language=TypeScript linguist-vendored=false linguist-detectable=true
frontend/app/**/*.tsx           linguist-language=TypeScript linguist-vendored=false linguist-detectable=true
frontend/components/**/*.tsx    linguist-language=TypeScript linguist-vendored=false linguist-detectable=true

# ============================================================
# 3. 🏗️ HCL — 3º LUGAR
# ============================================================
terraform/**/*.tf               linguist-language=HCL linguist-vendored=false linguist-detectable=true
terraform/.terraform.lock.hcl   linguist-language=HCL linguist-vendored=false linguist-generated=false linguist-detectable=true
backend/**/*.json               linguist-language=HCL linguist-vendored=false linguist-generated=false linguist-detectable=true

# ============================================================
# 4. 🐳 DOCKERFILE — 4º LUGAR
# ============================================================
Dockerfile* linguist-language=Dockerfile linguist-vendored=false linguist-detectable=true
backend/Dockerfile* linguist-language=Dockerfile linguist-vendored=false linguist-detectable=true
frontend/Dockerfile* linguist-language=Dockerfile linguist-vendored=false linguist-detectable=true
docker-compose*.yaml            linguist-language=Dockerfile linguist-vendored=false linguist-detectable=true
docker-compose*.yml             linguist-language=Dockerfile linguist-vendored=false linguist-detectable=true
.dockerignore                   linguist-language=Dockerfile linguist-vendored=false linguist-detectable=true
backend/mvnw.cmd                linguist-language=Dockerfile linguist-vendored=false linguist-detectable=true
frontend/package.json           linguist-language=Dockerfile linguist-vendored=false linguist-detectable=true